# ── Last.fm (one shared app key for everyone) ──────────────────────────────
# Get a key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ── Slack OAuth app (per-user "Add to Slack") ──────────────────────────────
# Create an app at https://api.slack.com/apps, add the user scopes
#   users.profile:write, users.profile:read, users:write, emoji:read
# and set the redirect URL below under OAuth & Permissions.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://slackpfp.christianwell.xyz/oauth/callback
# Restrict installs to the Hack Club workspace (default below).
ALLOWED_TEAM_ID=T0266FRGM

# Optional: a workspace bot token used only as a fallback for emoji lookups.
SLACK_BOT_TOKEN=

# ── Web app ────────────────────────────────────────────────────────────────
# Flask session signing key (random hex). Generate: python -c "import os;print(os.urandom(32).hex())"
SECRET_KEY=
# Encryption key for Slack tokens at rest. Generate: python -m db keygen
FERNET_KEY=
# Set to 1 behind HTTPS so session cookies are marked Secure.
COOKIE_SECURE=1
WEB_PORT=8091
